---
const univers = [
  {
    title: "Accessoires textiles",
    text: "Bandeaux, headbands, turbans et pièces textiles choisies pour leur tombé, leur douceur et leur allure.",
  },
  {
    title: "Bijoux",
    text: "Des bijoux délicats à porter chaque jour, entre détails subtils, finitions soignées et petites séries.",
  },
  {
    title: "Cadeaux & objets choisis",
    text: "Bougies, mugs et objets à offrir ou à s’offrir, pensés pour faire entrer un peu de beauté dans le quotidien.",
  },
  {
    title: "Créations artisanales",
    text: "Des pièces faites avec attention, où le geste, la matière et l’histoire de l’objet comptent autant que son style.",
  },
  {
    title: "Petites séries",
    text: "Des collections inspirées de voyages, de couleurs et de rencontres, imaginées en quantités limitées.",
  },
  {
    title: "DIY & atelier créatif",
    text: "Une place laissée au faire soi-même, aux idées à partager et aux moments créatifs qui rapprochent.",
  },
];

const engagements = [
  "Des matières choisies pour leur toucher, leur tenue et leur simplicité.",
  "Une sélection sensible, faite avec le goût des belles choses et des pièces durables.",
  "Des objets qui racontent quelque chose, loin des achats impersonnels.",
  "Un esprit boutique chaleureux, où l’on prend le temps de découvrir et d’échanger.",
];

const nouveautes = [
  "Les bandeaux et turbans aux tons doux, pensés pour accompagner les journées de saison.",
  "Les idées cadeaux délicates, entre bijoux, bougies et objets choisis avec soin.",
  "Les sweats, t-shirts et créations en petites séries qui donnent envie de revenir voir les nouveautés.",
];

const contact = {
  address: "21 rue du Lion d'Or, 59140 Dunkerque",
  phone: "06 10 71 10 30",
  email: "chezjeannette1935@gmail.com",
  instagram: "@chezjeannette_1935",
  maps: "https://www.google.com/maps/search/?api=1&query=21+rue+du+Lion+d'Or,+59140+Dunkerque",
  instagramUrl: "https://www.instagram.com/chezjeannette_1935/",
  facebookUrl: "https://www.facebook.com/",
};

const images = {
  hero:
    "https://images.pexels.com/photos/34427387/pexels-photo-34427387.jpeg?auto=compress&cs=tinysrgb&w=1400",
  textiles:
    "https://images.pexels.com/photos/33829425/pexels-photo-33829425.jpeg?auto=compress&cs=tinysrgb&w=1200",
  boutique:
    "https://images.pexels.com/photos/5865148/pexels-photo-5865148.jpeg?auto=compress&cs=tinysrgb&w=1200",
  ambiance:
    "https://images.pexels.com/photos/13771344/pexels-photo-13771344.jpeg?auto=compress&cs=tinysrgb&w=1200",
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Chez Jeannette 1935 | Maison de créateurs à Dunkerque</title>
    <meta
      name="description"
      content="Chez Jeannette 1935, maison de créateurs à Dunkerque. Une sélection délicate d’objets, d’accessoires et de créations choisies avec soin."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="#top">
          <span class="brand-kicker">Dunkerque</span>
          <span class="brand-name">Chez Jeannette 1935</span>
        </a>
        <nav class="main-nav" aria-label="Navigation principale">
          <a href="#maison">La maison</a>
          <a href="#univers">Nos univers</a>
          <a href="#boutique">La boutique</a>
          <a href="#visiter">Visiter</a>
        </nav>
      </header>

      <main id="top">
        <section class="hero">
          <div class="hero-copy">
            <p class="eyebrow">L’âme du fait main, à la française.</p>
            <h1>Maison de créateurs à Dunkerque</h1>
            <p class="lead">
              Une sélection délicate d’objets, d’accessoires et de créations
              choisies avec soin, dans une boutique chaleureuse où l’on vient
              autant pour découvrir que pour se faire plaisir.
            </p>
            <div class="hero-actions">
              <a class="button primary" href="#univers">Découvrir l’univers</a>
              <a class="button secondary" href="#visiter">Visiter la boutique</a>
              <a class="button ghost" href={`mailto:${contact.email}`}>Nous contacter</a>
            </div>
            <ul class="hero-notes" aria-label="Informations clés">
              <li>Accessoires textiles, bijoux, cadeaux et créations artisanales</li>
              <li>Boutique indépendante installée au cœur de Dunkerque</li>
              <li>Instagram, Facebook et boutique en ligne pour suivre les nouveautés</li>
            </ul>
          </div>

          <div class="hero-visual">
            <div class="photo-card photo-card-main">
              <img
                src={images.hero}
                alt="Présentation chaleureuse de bijoux et accessoires textiles dans un intérieur de boutique"
              />
            </div>
            <div class="hero-aside">
              <div class="note-card">
                <span class="note-label">Depuis 1935</span>
                <p>
                  Une adresse inspirante pour celles et ceux qui aiment les
                  pièces choisies, les matières naturelles et les belles idées à offrir.
                </p>
              </div>
              <div class="swatch-card">
                <span>Crème</span>
                <span>Sable</span>
                <span>Terracotta</span>
                <span>Feuillage</span>
              </div>
            </div>
          </div>
        </section>

        <section class="intro-strip">
          <p>
            Chez Jeannette 1935 réunit des accessoires, des objets et des
            créations qui ont une présence particulière. Ici, le geste
            artisanal, le choix des matières et l’envie de composer un univers
            doux et vivant sont au centre de tout.
          </p>
        </section>

        <section class="story section-grid" id="maison">
          <div class="section-heading">
            <span class="section-tag">L’esprit de la maison</span>
            <h2>Une maison de créateurs pensée comme une adresse précieuse</h2>
          </div>
          <div class="story-copy">
            <p>
              À Dunkerque, Chez Jeannette 1935 cultive une approche simple et
              soignée du fait main. On y découvre des pièces choisies pour leur
              délicatesse, leur singularité et la sensation qu’elles laissent.
            </p>
            <p>
              La boutique invite à prendre son temps, à regarder les détails, à
              toucher les matières et à composer des envies pour soi, pour offrir
              ou pour revenir plus tard avec une idée en tête.
            </p>
          </div>
        </section>

        <section class="univers section-grid" id="univers">
          <div class="section-heading">
            <span class="section-tag">Nos univers</span>
            <h2>Des sélections sensibles, pour la vie de tous les jours comme pour les attentions particulières</h2>
          </div>

          <div class="univers-layout">
            <div class="univers-cards">
              {univers.map((item) => (
                <article class="universe-card">
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </article>
              ))}
            </div>

            <aside class="editorial-stack">
              <figure class="editorial-photo tall">
                <img
                  src={images.textiles}
                  alt="Textiles artisanaux rangés avec soin dans une ambiance naturelle"
                />
              </figure>
              <div class="editorial-copy">
                <p class="mini-title">Une sélection sensible et soignée</p>
                <p>
                  Chaque pièce trouve sa place par sa matière, sa couleur, son
                  usage ou l’émotion qu’elle apporte. Rien n’est là par hasard.
                </p>
              </div>
            </aside>
          </div>
        </section>

        <section class="selection section-grid">
          <div class="section-heading">
            <span class="section-tag">La sélection</span>
            <h2>Le goût des belles pièces, sans ostentation</h2>
          </div>

          <div class="selection-content">
            <div class="commitments">
              {engagements.map((item) => (
                <div class="commitment">
                  <span class="marker"></span>
                  <p>{item}</p>
                </div>
              ))}
            </div>

            <figure class="editorial-photo wide">
              <img
                src={images.ambiance}
                alt="Ambiance de table chaleureuse avec objets choisis et lumière douce"
              />
            </figure>
          </div>
        </section>

        <section class="boutique section-grid" id="boutique">
          <div class="section-heading">
            <span class="section-tag">L’univers boutique</span>
            <h2>Une ambiance douce, locale et accueillante</h2>
          </div>

          <div class="boutique-layout">
            <figure class="editorial-photo large">
              <img
                src={images.boutique}
                alt="Objets choisis, bougies et cadeaux présentés dans une boutique chaleureuse"
              />
            </figure>

            <div class="boutique-copy">
              <p>
                Entrer chez Jeannette, c’est retrouver une boutique inspirante,
                lumineuse et chaleureuse, où les objets vivent ensemble avec
                beaucoup de naturel.
              </p>
              <p>
                L’esprit du lieu est intime, féminin et accessible. On y vient
                pour découvrir une sélection locale et créative, pour préparer un
                cadeau, pour trouver un accessoire qui change tout ou simplement
                pour prendre le temps d’aimer les belles choses.
              </p>
            </div>
          </div>
        </section>

        <section class="news section-grid">
          <div class="section-heading">
            <span class="section-tag">Idées cadeaux & nouveautés</span>
            <h2>Des arrivages choisis pour donner envie de revenir</h2>
          </div>

          <div class="news-panel">
            <div class="news-list">
              {nouveautes.map((item) => (
                <article class="news-item">
                  <p>{item}</p>
                </article>
              ))}
            </div>

            <div class="social-panel">
              <p>
                Pour suivre les sélections du moment, les nouvelles pièces et
                l’ambiance de la boutique, Instagram reste le plus beau carnet de
                bord de la maison.
              </p>
              <div class="social-actions">
                <a class="button primary" href={contact.instagramUrl} target="_blank" rel="noreferrer">
                  Suivre sur Instagram
                </a>
                <a class="button secondary" href={contact.facebookUrl} target="_blank" rel="noreferrer">
                  Voir Facebook
                </a>
              </div>
            </div>
          </div>
        </section>

        <section class="visit section-grid" id="visiter">
          <div class="section-heading">
            <span class="section-tag">Visiter la boutique</span>
            <h2>Une adresse à découvrir au cœur de Dunkerque</h2>
          </div>

          <div class="visit-card">
            <div>
              <p class="visit-label">Adresse</p>
              <p>{contact.address}</p>
            </div>
            <div>
              <p class="visit-label">Téléphone</p>
              <p><a href={`tel:${contact.phone.replace(/\s/g, "")}`}>{contact.phone}</a></p>
            </div>
            <div>
              <p class="visit-label">Email</p>
              <p><a href={`mailto:${contact.email}`}>{contact.email}</a></p>
            </div>
            <div>
              <p class="visit-label">Instagram</p>
              <p><a href={contact.instagramUrl} target="_blank" rel="noreferrer">{contact.instagram}</a></p>
            </div>
            <div class="visit-actions">
              <a class="button primary" href={contact.maps} target="_blank" rel="noreferrer">
                Itinéraire
              </a>
              <a class="button ghost" href={`mailto:${contact.email}`}>
                Contact
              </a>
            </div>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <div>
          <p class="footer-brand">Chez Jeannette 1935</p>
          <p>Maison de créateurs à Dunkerque</p>
        </div>
        <div class="footer-links">
          <a href={contact.instagramUrl} target="_blank" rel="noreferrer">Instagram</a>
          <a href={contact.facebookUrl} target="_blank" rel="noreferrer">Facebook</a>
          <a href={`mailto:${contact.email}`}>Contact</a>
        </div>
        <p class="footer-note">Photographies éditoriales issues de Pexels.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  :root {
    --bg: #f6f0e7;
    --bg-soft: #efe4d6;
    --card: rgba(255, 250, 244, 0.72);
    --text: #332a24;
    --muted: #6e6258;
    --line: rgba(72, 56, 44, 0.14);
    --sand: #d9c5ae;
    --terracotta: #b86b4d;
    --terracotta-deep: #8f4f37;
    --leaf: #395143;
    --anthracite: #2f3436;
    --shadow: 0 24px 60px rgba(59, 43, 30, 0.12);
    --radius-xl: 32px;
    --radius-lg: 24px;
    --radius-md: 18px;
    --content: 1180px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: "Manrope", sans-serif;
    color: var(--text);
    background:
      radial-gradient(circle at top left, rgba(217, 197, 174, 0.35), transparent 26%),
      radial-gradient(circle at 85% 20%, rgba(184, 107, 77, 0.12), transparent 18%),
      linear-gradient(180deg, #fbf6ef 0%, var(--bg) 48%, #f3eadf 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-shell {
    width: min(calc(100% - 32px), var(--content));
    margin: 0 auto;
    padding: 24px 0 56px;
  }

  .site-header {
    position: sticky;
    top: 16px;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 18px 22px;
    background: rgba(251, 246, 239, 0.76);
    border: 1px solid rgba(98, 75, 56, 0.08);
    border-radius: 999px;
    backdrop-filter: blur(18px);
    box-shadow: 0 10px 30px rgba(53, 38, 27, 0.08);
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-kicker,
  .eyebrow,
  .section-tag,
  .visit-label,
  .note-label {
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.72rem;
    color: var(--terracotta-deep);
  }

  .brand-name,
  h1,
  h2,
  h3,
  .footer-brand {
    font-family: "Cormorant Garamond", serif;
  }

  .brand-name {
    font-size: 1.5rem;
    font-weight: 600;
  }

  .main-nav {
    display: flex;
    gap: 22px;
    font-size: 0.95rem;
    color: var(--muted);
  }

  .hero,
  .section-grid,
  .intro-strip,
  .site-footer {
    margin-top: 28px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 34px;
    align-items: center;
    min-height: calc(100vh - 140px);
    padding: 34px 0 8px;
  }

  .hero-copy {
    max-width: 610px;
  }

  h1 {
    margin: 12px 0 18px;
    font-size: clamp(3.8rem, 7vw, 6.6rem);
    line-height: 0.92;
    font-weight: 600;
  }

  .lead,
  .story-copy p,
  .boutique-copy p,
  .social-panel p,
  .intro-strip p,
  .editorial-copy p,
  .visit-card p {
    font-size: 1.04rem;
    line-height: 1.8;
    color: var(--muted);
  }

  .hero-actions,
  .social-actions,
  .visit-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 600;
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    background: var(--anthracite);
    color: #fff9f3;
  }

  .button.secondary {
    background: rgba(217, 197, 174, 0.28);
    border-color: rgba(143, 79, 55, 0.18);
  }

  .button.ghost {
    border-color: rgba(57, 81, 67, 0.26);
    color: var(--leaf);
    background: rgba(255, 255, 255, 0.36);
  }

  .hero-notes {
    display: grid;
    gap: 10px;
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
    color: var(--text);
  }

  .hero-notes li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .hero-notes li::before {
    content: "";
    width: 8px;
    height: 8px;
    margin-top: 9px;
    border-radius: 50%;
    background: var(--terracotta);
    flex: 0 0 auto;
  }

  .hero-visual {
    display: grid;
    gap: 18px;
  }

  .photo-card,
  .editorial-photo,
  .note-card,
  .swatch-card,
  .intro-strip,
  .universe-card,
  .news-item,
  .social-panel,
  .visit-card {
    border: 1px solid var(--line);
    background: var(--card);
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow);
  }

  .photo-card-main {
    min-height: 680px;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .hero-aside {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 18px;
  }

  .note-card,
  .swatch-card {
    border-radius: var(--radius-lg);
    padding: 22px;
  }

  .note-card p,
  .swatch-card span,
  .commitment p,
  .news-item p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .swatch-card {
    display: grid;
    gap: 10px;
    align-content: start;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.58), rgba(244, 231, 214, 0.74)),
      linear-gradient(135deg, rgba(184, 107, 77, 0.18), rgba(57, 81, 67, 0.08));
  }

  .intro-strip {
    padding: 28px 30px;
    border-radius: var(--radius-lg);
  }

  .section-grid {
    display: grid;
    gap: 28px;
    padding: 42px 0 0;
  }

  .section-heading {
    display: grid;
    gap: 10px;
    max-width: 760px;
  }

  h2 {
    margin: 0;
    font-size: clamp(2.3rem, 4vw, 3.7rem);
    line-height: 0.98;
    font-weight: 600;
  }

  .univers-layout,
  .selection-content,
  .boutique-layout,
  .news-panel {
    display: grid;
    grid-template-columns: 1fr 0.86fr;
    gap: 24px;
    align-items: start;
  }

  .univers-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .universe-card,
  .news-item {
    padding: 24px;
    border-radius: var(--radius-md);
  }

  h3 {
    margin: 0 0 10px;
    font-size: 1.7rem;
    font-weight: 600;
  }

  .universe-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .editorial-stack,
  .commitments,
  .news-list {
    display: grid;
    gap: 18px;
  }

  .editorial-photo {
    overflow: hidden;
    border-radius: var(--radius-xl);
  }

  .editorial-photo.tall {
    min-height: 640px;
  }

  .editorial-photo.wide,
  .editorial-photo.large {
    min-height: 520px;
  }

  .editorial-copy,
  .social-panel {
    padding: 26px;
    border-radius: var(--radius-lg);
  }

  .mini-title {
    margin: 0 0 10px;
    color: var(--text);
    font-weight: 700;
    font-size: 1rem;
  }

  .commitment {
    display: grid;
    grid-template-columns: 18px 1fr;
    gap: 14px;
    align-items: start;
    padding: 20px 22px;
    border-radius: var(--radius-md);
    background: rgba(255, 250, 244, 0.72);
    border: 1px solid var(--line);
  }

  .marker {
    width: 18px;
    height: 18px;
    margin-top: 6px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 30% 30%, #f5d8c9 0, #f5d8c9 18%, var(--terracotta) 20%, var(--terracotta-deep) 100%);
  }

  .visit-card {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
    padding: 28px;
    border-radius: var(--radius-xl);
  }

  .visit-card a:hover,
  .main-nav a:hover,
  .footer-links a:hover {
    color: var(--terracotta-deep);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: flex-end;
    padding: 28px 0 8px;
    border-top: 1px solid rgba(72, 56, 44, 0.12);
  }

  .footer-brand {
    margin: 0 0 6px;
    font-size: 1.7rem;
  }

  .footer-links {
    display: flex;
    gap: 18px;
    color: var(--muted);
  }

  .footer-note,
  .site-footer p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 1080px) {
    .hero,
    .univers-layout,
    .selection-content,
    .boutique-layout,
    .news-panel,
    .visit-card {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding-top: 20px;
    }

    .photo-card-main,
    .editorial-photo.tall,
    .editorial-photo.wide,
    .editorial-photo.large {
      min-height: 420px;
    }

    .visit-card {
      gap: 18px;
    }
  }

  @media (max-width: 820px) {
    .page-shell {
      width: min(calc(100% - 20px), var(--content));
      padding-top: 12px;
    }

    .site-header,
    .hero-aside,
    .main-nav,
